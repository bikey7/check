@{
    ViewData["Title"] = "Write a Review";
}

<h1>Write a Review for @ViewBag.RestaurantName</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <input type="hidden" name="restaurantId" value="@ViewBag.RestaurantId" />

                    <div class="form-group mb-3">
                        <label class="control-label">Rating</label>
                        <div>
                            @for (int i = 1; i <= 5; i++)
                            {
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="rating" id="rating@i" value="@i"
                                           required>
                                    <label class="form-check-label" for="rating@i">@i Star@(i > 1 ? "s" : "")</label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label for="comment" class="control-label">Your Review</label>
                        <textarea name="comment" id="comment" class="form-control" rows="5" required
                                  minlength="10"></textarea>
                        <small class="text-muted">Minimum 10 characters</small>
                    </div>

                    <div class="form-group mb-3">
                        <input type="submit" value="Submit Review" class="btn btn-primary" />
                        <a asp-controller="Restaurant" asp-action="Details" asp-route-id="@ViewBag.RestaurantId"
                           class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Guidelines</h5>
                <ul>
                    <li>Be honest</li>
                    <li>Focus on your experience</li>
                    <li>No offensive language</li>
                </ul>
            </div>
        </div>
    </div>
</div>