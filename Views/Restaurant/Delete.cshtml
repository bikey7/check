@model restaurantfinalupdated.Models.Restaurant

@{
    ViewData["Title"] = "Delete Restaurant";
}

<h1>Delete Restaurant</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this?</h3>
</div>

<div class="card">
    <div class="card-body">
        <h4>@Model.Name</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Cuisine</dt>
            <dd class="col-sm-9">@Model.CuisineType</dd>

            <dt class="col-sm-3">Location</dt>
            <dd class="col-sm-9">@Model.Location</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.IsApproved)
                {
                    <span class="badge bg-success">Approved</span>
                }
                else
                {
                    <span class="badge bg-warning">Pending</span>
                }
            </dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <a asp-action="MyRestaurants" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>