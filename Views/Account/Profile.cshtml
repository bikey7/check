@model restaurantfinalupdated.Models.User

@{
    ViewData["Title"] = "My Profile";
}

<h1>My Profile</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Account Information</h5>

                <dl class="row">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Role</dt>
                    <dd class="col-sm-8">@Model.Role</dd>

                    <dt class="col-sm-4">Member Since</dt>
                    <dd class="col-sm-8">@Model.RegistrationDate.ToShortDateString()</dd>
                </dl>
            </div>
        </div>
    </div>

    @if (Model.Role == "Owner" && Model.OwnedRestaurants != null && Model.OwnedRestaurants.Any())
    {
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">My Restaurants</h5>
                    <ul class="list-group">
                        @foreach (var restaurant in Model.OwnedRestaurants)
                        {
                            <li class="list-group-item">@restaurant.Name</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    }
</div>